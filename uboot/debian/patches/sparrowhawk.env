autoconf_mmc=setenv bootargs "rw root=/dev/mmcblk0p1 rootwait" && load mmc 0:1 ${loadaddr} /boot/fitImage && source ${loadaddr}:script
autoconf_nvme=pci e && nvme scan && setenv bootargs "rw root=/dev/nvme0n1p1 rootwait" && load nvme 0:1 ${loadaddr} /boot/fitImage && source ${loadaddr}:script
autoconf_usb=pci e && usb start && setenv bootargs "rw root=/dev/sda1 rootwait ignore_loglevel" && load usb 0:1 ${loadaddr} /boot/fitImage && source ${loadaddr}:script
flash_pcie_fw_to_qspi_from_mmc=load mmc 0:1 ${loadaddr} lib/firmware/rcar_gen4_pcie.bin && sf probe; sf update ${loadaddr} 0x300000 ${filesize}
renesas_rcar_gen4_load_firmware=run set_pcie_firmware_info;sf probe; sf read ${renesas_rcar_gen4_load_firmware_addr} 0x300000 ${renesas_rcar_gen4_load_firmware_size}
set_pcie_firmware_info=setenv renesas_rcar_gen4_load_firmware_addr 0x54000000 && setenv renesas_rcar_gen4_load_firmware_size 0x8000
update_loader_from_mmc=load mmc 0:1 ${loadaddr} flash.bin && sf probe && sf update ${loadaddr} 0 ${filesize} && reset
update_loader_from_usb=pci e; usb start; load usb 0:1 ${loadaddr} flash.bin && sf probe && sf update ${loadaddr} 0 ${filesize} && reset
update_loader_from_nvme=pci e; nvme scan; load nvme 0:1 ${loadaddr} flash.bin && sf probe && sf update ${loadaddr} 0 ${filesize} && reset
