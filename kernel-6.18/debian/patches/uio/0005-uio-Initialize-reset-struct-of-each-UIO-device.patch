From a2c32fad439d6978ce655477e44fd0b453d8ef76 Mon Sep 17 00:00:00 2001
From: Khiem Nguyen <khiem.nguyen.xt@renesas.com>
Date: Wed, 3 Feb 2021 18:32:23 +0700
Subject: [PATCH 05/15] uio: Initialize reset struct of each UIO device

To make reset function work, the reset struct must be initialized.
This patch adds the lacked initialization which allocates a reset
for a specific UIO device.
The shared reset line is not supported. And UIO devices are allowed to
not have their own reset lines as well.

Signed-off-by: Khiem Nguyen <khiem.nguyen.xt@renesas.com>
---
 drivers/uio/uio_pdrv_genirq.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/drivers/uio/uio_pdrv_genirq.c b/drivers/uio/uio_pdrv_genirq.c
index 1397f48af512..9870222600d9 100644
--- a/drivers/uio/uio_pdrv_genirq.c
+++ b/drivers/uio/uio_pdrv_genirq.c
@@ -429,6 +429,12 @@ static int uio_pdrv_genirq_probe(struct platform_device *pdev)
 	priv->clk_cnt = 0;
 	priv->pwr_cnt = 0;
 
+	priv->rst = devm_reset_control_get_optional_exclusive(&pdev->dev, NULL);
+	if (IS_ERR(priv->rst)) {
+		dev_err(&pdev->dev, "failed to get cpg reset\n");
+		return PTR_ERR(priv->rst);
+	}
+
 	if (!uioinfo->irq) {
 		ret = platform_get_irq_optional(pdev, 0);
 		uioinfo->irq = ret;
-- 
