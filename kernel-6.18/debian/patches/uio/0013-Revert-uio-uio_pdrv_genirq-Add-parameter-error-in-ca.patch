From 763437c32d267af3a7355be9104cfaf456aa5f3b Mon Sep 17 00:00:00 2001
From: Hai Pham <hai.pham.ud@renesas.com>
Date: Wed, 1 Feb 2023 16:01:16 +0700
Subject: [PATCH 13/15] Revert "uio: uio_pdrv_genirq: Add parameter error in
 case not define property in node"

This reverts commit b8833263b7f08112197391946447a762788c7c9c.

Signed-off-by: Hai Pham <hai.pham.ud@renesas.com>
---
 drivers/uio/uio_pdrv_genirq.c | 38 +----------------------------------
 1 file changed, 1 insertion(+), 37 deletions(-)

diff --git a/drivers/uio/uio_pdrv_genirq.c b/drivers/uio/uio_pdrv_genirq.c
index 1cfdaf79a64c..0dc7c30fb4a7 100644
--- a/drivers/uio/uio_pdrv_genirq.c
+++ b/drivers/uio/uio_pdrv_genirq.c
@@ -45,7 +45,6 @@ struct uio_pdrv_genirq_platdata {
 	struct reset_control *rst;
 	int pwr_cnt;
 	int clk_cnt;
-	bool pd;
 };
 
 static int local_pm_runtime_get_sync(struct uio_pdrv_genirq_platdata *priv);
@@ -149,11 +148,6 @@ static int priv_set_pwr(struct uio_info *info, int value)
 	int ret = 0;
 	struct uio_pdrv_genirq_platdata *priv = info->priv;
 
-	if (priv->pd) {
-		dev_err(&priv->pdev->dev, "device has not power-domains to set\n");
-		return -EOPNOTSUPP;
-	}
-
 	if (((value == 0) && priv->pwr_cnt > 0) || ((value != 0)
 		    && priv->pwr_cnt == 0)) {
 		if (value == 0)
@@ -175,11 +169,6 @@ static int priv_get_pwr(struct uio_info *info)
 {
 	struct uio_pdrv_genirq_platdata *priv = info->priv;
 
-	if (priv->pd) {
-		dev_err(&priv->pdev->dev, "device has not power-domains to get\n");
-		return -EOPNOTSUPP;
-	}
-
 	dev_dbg(&priv->pdev->dev, "Get power state pwr_cnt=%d, clk_cnt=%d\n",
 		priv->pwr_cnt, priv->clk_cnt);
 
@@ -196,11 +185,6 @@ static int priv_set_clk(struct uio_info *info, int value)
 	int ret = 0;
 	struct uio_pdrv_genirq_platdata *priv = info->priv;
 
-	if (!priv->clk) {
-		dev_err(&priv->pdev->dev, "device has not clk to set\n");
-		return -EOPNOTSUPP;
-	}
-
 	if (value == 0)
 		local_clk_disable(priv);
 	else
@@ -220,11 +204,6 @@ static int priv_get_clk(struct uio_info *info)
 {
 	struct uio_pdrv_genirq_platdata *priv = info->priv;
 
-	if (!priv->clk) {
-		dev_err(&priv->pdev->dev, "device has not clk to get\n");
-		return -EOPNOTSUPP;
-	}
-
 	dev_dbg(&priv->pdev->dev, "Get clock state - clk_cnt=%d\n",
 		priv->clk_cnt);
 
@@ -283,11 +262,6 @@ static int priv_set_rst(struct uio_info *info, int value)
 	struct uio_pdrv_genirq_platdata *priv = info->priv;
 	int status, ret;
 
-	if (!priv->rst) {
-		dev_err(&priv->pdev->dev, "device has not reset to set\n");
-		return -EOPNOTSUPP;
-	}
-
 	status = reset_control_status(priv->rst);
 
 	switch (value) {
@@ -314,10 +288,8 @@ static int priv_get_rst(struct uio_info *info)
 	struct uio_pdrv_genirq_platdata *priv = info->priv;
 	int status;
 
-	if (!priv->rst) {
-		dev_err(&priv->pdev->dev, "device has not reset to get\n");
+	if (!priv->rst)
 		return -EOPNOTSUPP;
-	}
 
 	status = reset_control_status(priv->rst);
 	dev_dbg(&priv->pdev->dev, "Get reset state 0x%x\n", status);
@@ -558,14 +530,6 @@ static int uio_pdrv_genirq_probe(struct platform_device *pdev)
 	 */
 	pm_runtime_enable(&pdev->dev);
 
-	if (!of_property_read_bool(node, "power-domains")) {
-		dev_dbg(&pdev->dev, "device has not power-domains property\n");
-		pm_runtime_get_sync(&pdev->dev);
-		pm_runtime_put_sync(&pdev->dev);
-		pm_runtime_disable(&pdev->dev);
-		priv->pd = 1;
-        }
-
 	ret = devm_add_action_or_reset(&pdev->dev, uio_pdrv_genirq_cleanup,
 				       &pdev->dev);
 	if (ret)
