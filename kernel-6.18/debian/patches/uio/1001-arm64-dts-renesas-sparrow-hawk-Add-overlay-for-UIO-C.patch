diff --git a/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk-cmem.dtsi b/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk-cmem.dtsi
new file mode 100644
index 000000000000..76f063fa0228
--- /dev/null
+++ b/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk-cmem.dtsi
@@ -0,0 +1,59 @@
+&{/} {
+	reserved-memory {
+		#address-cells = <2>;
+		#size-cells = <2>;
+		range;
+
+		/* global autoconfigured region for contiguous allocations */
+		cma@70000000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x00000000 0x70000000 0x0 0x30000000>;
+			linux,cma-default;
+		};
+	
+		region_40bit: region_40bit@600000000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x6 0x00000000 0x0 0x40000000>;
+		};
+
+		vdsp0_region: vdsp0_region@5d000000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x00000000 0x5d000000 0x0 0x00800000>;
+		};
+
+		vdsp1_region: vdsp1_region@5d800000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x00000000 0x5d800000 0x0 0x00800000>;
+		};
+
+		vdsp2_region: vdsp2_region@5e000000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x00000000 0x5e000000 0x0 0x00800000>;
+		};
+
+		vdsp3_region: vdsp3_region@5e800000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x00000000 0x5e800000 0x0 0x00800000>;
+		};
+
+		pap_region: pap_region@5f000000 {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x00000000 0x5f000000 0x0 0x00400000>;
+		};
+	};
+
+	cmem {
+		compatible = "renesas,cmem";
+		memory-region = <&vdsp0_region &vdsp1_region
+				 &vdsp2_region &vdsp3_region
+				 &pap_region &region_40bit>;
+	};
+};
+
